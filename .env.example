# ---- Food Pilot — environment variables (copy to .env and fill in) ----

# LLM (Groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Restaurant discovery
APIFY_API_TOKEN=

# Web search for menus / deals
TAVILY_API_KEY=

# Tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=food-pilot

# Optional: default search radius (km) for the scoring formula
MAX_DISTANCE_KM=10
