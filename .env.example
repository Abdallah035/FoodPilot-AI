# ---- Food Pilot — environment variables (copy to .env and fill in) ----

# Azure OpenAI chat model
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=

# Restaurant discovery
APIFY_API_TOKEN=
# Web search for menus / deals
TAVILY_API_KEY=

# Tracing
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=
LANGSMITH_PROJECT=food-pilot

# Optional: default search radius (km) for the scoring formula
MAX_DISTANCE_KM=10

# Optional Azure OpenAI embedding configuration, currently unused.
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_EMBEDDING_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT_NAME=
